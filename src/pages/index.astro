---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Amauta" description="Laboratorios virtuales 2D de ciencias para estudiantes colombianos de secundaria. Gratuito, mobile-first, sin login.">
  <main class="flex min-h-screen flex-col items-center justify-center px-4 text-center">
    <h1 class="text-4xl font-semibold tracking-tight text-neutral-900">
      Amauta
    </h1>
    <p class="mt-4 max-w-md text-lg text-neutral-600">
      Laboratorios virtuales de ciencias para estudiantes colombianos.
      Gratuito · Sin login · Mobile-first.
    </p>
    <a
      href="/labs"
      class="mt-8 inline-block rounded-lg bg-neutral-900 px-6 py-3 text-base font-medium text-white hover:bg-neutral-700"
    >
      Ver laboratorios →
    </a>
  </main>
</BaseLayout>
