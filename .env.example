# Copia este archivo a .env.local y completa los valores.
# .env.local está en .gitignore — nunca lo subas al repo.

# GitHub MCP — necesario para gestionar issues, PRs y releases desde Claude.
# Cómo obtenerlo: github.com/settings/tokens → New token → scopes: repo, issues, pull_requests
GITHUB_PERSONAL_ACCESS_TOKEN=

# Cloudflare MCP — necesario para deploys y gestión de Cloudflare Pages desde Claude.
# Cómo obtenerlo: dash.cloudflare.com/profile/api-tokens → Create Token → Edit Cloudflare Pages
CLOUDFLARE_API_TOKEN=

# Brave Search MCP (opcional, Nivel 2) — búsquedas web desde Claude sin salir del flujo.
# Plan gratuito: 2,000 req/mes. Obtener en: api.search.brave.com
# BRAVE_API_KEY=
